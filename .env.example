# ============================================================
# Wall Street Bro - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- xAI / Grok ---
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.1-fast

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SUPERVISOR_MODEL=claude-haiku-4-5-20251001
EXECUTION_MODEL=claude-sonnet-4-5
VISUALIZATION_MODEL=claude-haiku-4-5-20251001

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://wallstreetbro:wallstreetbro@localhost:5432/wallstreetbro

# --- Alpaca Trading (use paper trading URL for testing) ---
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Risk Management ---
MAX_DRAWDOWN_PCT=0.05
MAX_POSITION_SIZE_USD=10000
RATE_LIMIT_BUFFER_PCT=0.80

# --- Grok Scan Configuration ---
# JSON array of up to 10 X handles to include in scans
ALLOWED_X_HANDLES=["elonmusk","federalreserve","SecGov","IMFNews","WorldBank"]
# JSON array of X handles to exclude (noise/bots)
EXCLUDED_X_HANDLES=[]
ENABLE_IMAGE_UNDERSTANDING=false

# --- Google Sheets (optional logging sink) ---
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
